<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= guild.name %> - الإعدادات</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="dark-bg">
<%- include('partials/header', { user, botAvatar: botAvatar || '', isOwner: isOwner || false }) %>

<div class="guild-layout">
  <aside class="sidebar">
    <div class="sidebar-guild">
      <img src="<%= guild.icon %>" alt="<%= guild.name %>" class="sidebar-guild-icon">
      <div>
        <h3><%= guild.name %></h3>
        <p><%= guild.memberCount.toLocaleString() %> عضو</p>
        <% if (settings.premium) { %><span class="badge-premium">👑 Premium</span><% } %>
      </div>
    </div>
    <nav class="sidebar-nav">
      <a href="#" class="sidebar-link active" onclick="showTab('general',this)"><i class="fas fa-cog"></i> عام</a>
      <a href="#" class="sidebar-link" onclick="showTab('commands',this)"><i class="fas fa-terminal"></i> الأوامر</a>
      <a href="#" class="sidebar-link" onclick="showTab('welcome',this)"><i class="fas fa-door-open"></i> ترحيب</a>
      <a href="#" class="sidebar-link" onclick="showTab('autoreply',this)"><i class="fas fa-comment-dots"></i> رد تلقائي</a>
      <a href="#" class="sidebar-link" onclick="showTab('ai',this)"><i class="fas fa-robot"></i> ذكاء اصطناعي</a>
      <a href="#" class="sidebar-link" onclick="showTab('protection',this)"><i class="fas fa-shield-alt"></i> حماية</a>
      <a href="#" class="sidebar-link" onclick="showTab('logs',this)"><i class="fas fa-scroll"></i> اللوج</a>
      <a href="#" class="sidebar-link" onclick="showTab('moderation',this)"><i class="fas fa-gavel"></i> إشراف</a>
      <a href="#" class="sidebar-link" onclick="showTab('tax',this)"><i class="fas fa-coins"></i> ضريبة</a>
      <a href="#" class="sidebar-link" onclick="showTab('suggestions',this)"><i class="fas fa-lightbulb"></i> اقتراحات</a>
      <a href="#" class="sidebar-link" onclick="showTab('feedback',this)"><i class="fas fa-comments"></i> آراء</a>
      <a href="#" class="sidebar-link" onclick="showTab('azkar',this)"><i class="fas fa-moon"></i> أذكار</a>
      <a href="#" class="sidebar-link" onclick="showTab('ticket',this)"><i class="fas fa-ticket-alt"></i> تكت</a>
      <a href="#" class="sidebar-link" onclick="showTab('levels',this)"><i class="fas fa-star"></i> مستويات</a>
      <a href="#" class="sidebar-link" onclick="showTab('whitelist',this)"><i class="fas fa-shield-check"></i> وايت ليست</a>
      <a href="#" class="sidebar-link premium-link" onclick="showTab('premium',this)"><i class="fas fa-crown"></i> Premium</a>
      <a href="/dashboard" class="sidebar-link back-link"><i class="fas fa-arrow-right"></i> رجوع</a>
    </nav>
  </aside>

  <main class="guild-content">
    <div id="toast" class="toast hidden"></div>

    <!-- TAB: GENERAL -->
    <div id="tab-general" class="tab-content active">
      <div class="tab-header"><h2><i class="fas fa-cog"></i> الإعدادات العامة</h2></div>
      <div class="settings-card">
        <h3>🔤 البريفكس</h3>
        <div class="input-row">
          <input type="text" id="prefix" value="<%= settings.prefix %>" maxlength="5" class="input-field" placeholder="!">
          <button onclick="saveSection('general',{prefix:document.getElementById('prefix').value})" class="btn-save">💾 حفظ</button>
        </div>
      </div>
      <div class="settings-card">
        <h3>📊 معلومات السيرفر</h3>
        <div class="info-grid">
          <div class="info-item"><span>الاسم</span><strong><%= guild.name %></strong></div>
          <div class="info-item"><span>الأعضاء</span><strong><%= guild.memberCount.toLocaleString() %></strong></div>
          <div class="info-item"><span>الرومات</span><strong><%= guild.channels.length %></strong></div>
          <div class="info-item"><span>الرتب</span><strong><%= guild.roles.length %></strong></div>
          <div class="info-item"><span>البريميوم</span><strong><%= settings.premium ? '👑 مفعّل' : '❌ غير مفعّل' %></strong></div>
        </div>
      </div>
    </div>

    <!-- TAB: COMMANDS -->
    <div id="tab-commands" class="tab-content">
      <div class="tab-header">
        <h2><i class="fas fa-terminal"></i> إعدادات الأوامر</h2>
        <p class="tab-desc">خصّص الأوامر وأضف اختصارات لكل أمر</p>
      </div>

      <!-- البريفكس -->
      <div class="settings-card">
        <h3>🔤 البريفكس</h3>
        <p class="settings-desc">البريفكس الحالي: <code id="prefix-display"><%= settings.prefix %></code></p>
        <div class="input-row">
          <input type="text" id="cmd_prefix" value="<%= settings.prefix %>" maxlength="5" class="input-field" placeholder="!">
          <button onclick="saveSection('general',{prefix:document.getElementById('cmd_prefix').value}).then(()=>{document.getElementById('prefix-display').textContent=document.getElementById('cmd_prefix').value})" class="btn-save">💾 حفظ</button>
        </div>
      </div>

      <!-- اختصارات الأوامر العامة -->
      <div class="settings-card">
        <h3>🔧 اختصارات الأوامر العامة</h3>
        <p class="settings-desc">حدد اختصاراً لكل أمر - يشتغل مع الأمر الأصلي أو بدله</p>
        <div class="shortcuts-grid">
          <% const generalCmds = [
            {key:'help',    emoji:'📋', desc:'قائمة الأوامر'},
            {key:'ping',    emoji:'🏓', desc:'سرعة البوت'},
            {key:'server',  emoji:'🏠', desc:'معلومات السيرفر'},
            {key:'user',    emoji:'👤', desc:'معلومات عضو'},
            {key:'avatar',  emoji:'🖼️', desc:'صورة عضو'},
            {key:'tax',     emoji:'💰', desc:'حساب الضريبة'},
          ] %>
          <% generalCmds.forEach(c => { %>
          <div class="shortcut-item-multi">
            <div class="shortcut-info">
              <span class="cmd-emoji"><%= c.emoji %></span>
              <div>
                <strong><code><%= settings.prefix %><%= c.key %></code></strong>
                <small><%= c.desc %></small>
              </div>
            </div>
            <div class="shortcut-aliases">
              <% for(let i=1; i<=10; i++) { %>
              <input type="text"
                id="sc_<%= c.key %>_<%= i %>"
                value="<%= (settings['sc_'+c.key+'_'+i]) || '' %>"
                class="alias-input"
                placeholder="اسم <%= i %>">
              <% } %>
            </div>
          </div>
          <% }) %>
        </div>
        <button onclick="saveAliases(['help','ping','server','user','avatar','tax'])" class="btn-save" style="margin-top:1rem">💾 حفظ أسماء العامة</button>
      </div>

      <!-- اختصارات أوامر الإشراف -->
      <div class="settings-card">
        <h3>⚙️ اختصارات أوامر الإشراف</h3>
        <p class="settings-desc">اختصارات تشتغل بنفس صلاحيات الأمر الأصلي</p>
        <div class="shortcuts-grid">
          <% const modCmds = [
            {key:'ban',    emoji:'🔨', desc:'حظر عضو'},
            {key:'unban',  emoji:'🔓', desc:'رفع الحظر'},
            {key:'kick',   emoji:'👟', desc:'طرد عضو'},
            {key:'mute',   emoji:'🔇', desc:'تايم أوت'},
            {key:'unmute', emoji:'🔊', desc:'رفع التايم أوت'},
            {key:'clear',  emoji:'🗑️', desc:'حذف رسائل'},
            {key:'lock',   emoji:'🔒', desc:'قفل الروم'},
            {key:'unlock', emoji:'🔓', desc:'فتح الروم'},
            {key:'hide',   emoji:'👁️', desc:'إخفاء الروم'},
            {key:'unhide', emoji:'✅', desc:'إظهار الروم'},
            {key:'say',    emoji:'💬', desc:'إرسال رسالة'},
            {key:'come',   emoji:'📩', desc:'استدعاء عضو'},
          ] %>
          <% modCmds.forEach(c => { %>
          <div class="shortcut-item-multi">
            <div class="shortcut-info">
              <span class="cmd-emoji"><%= c.emoji %></span>
              <div>
                <strong><code><%= settings.prefix %><%= c.key %></code></strong>
                <small><%= c.desc %></small>
              </div>
            </div>
            <div class="shortcut-aliases">
              <% for(let i=1; i<=10; i++) { %>
              <input type="text"
                id="sc_<%= c.key %>_<%= i %>"
                value="<%= (settings['sc_'+c.key+'_'+i]) || '' %>"
                class="alias-input"
                placeholder="اسم <%= i %>">
              <% } %>
            </div>
          </div>
          <% }) %>
        </div>
        <button onclick="saveAliases(['ban','unban','kick','mute','unmute','clear','lock','unlock','hide','unhide','say','come'])" class="btn-save" style="margin-top:1rem">💾 حفظ أسماء الإشراف</button>
      </div>

      <!-- أوامر مخصصة -->
      <div class="settings-card">
        <h3>✨ أوامر مخصصة</h3>
        <p class="settings-desc">أضف أوامر خاصة بسيرفرك - لما حد يكتب الأمر البوت يرد برسالة محددة</p>
        <div class="input-row" style="gap:0.5rem;flex-wrap:wrap">
          <input type="text" id="custom_cmd" class="input-field" placeholder="اسم الأمر (بدون بريفكس)" style="flex:1;min-width:120px">
          <input type="text" id="custom_reply" class="input-field" placeholder="الرد..." style="flex:2;min-width:180px">
          <button onclick="addCustomCmd()" class="btn-save">➕ إضافة</button>
        </div>
        <div id="custom-cmds-list" style="margin-top:1rem">
          <% const customCmds = settings.custom_cmds || []; %>
          <% if(customCmds.length === 0) { %>
            <p class="empty-text">لا توجد أوامر مخصصة بعد</p>
          <% } else { %>
            <% customCmds.forEach((c,i) => { %>
            <div class="reply-item" id="cc_<%= i %>">
              <div class="reply-info">
                <span class="reply-word"><%= settings.prefix %><%= c.cmd %></span>
                <span class="reply-arrow">→</span>
                <span class="reply-text"><%= c.reply %></span>
              </div>
              <button onclick="removeCustomCmd('<%= c.cmd %>')" class="btn-sm-danger">🗑️</button>
            </div>
            <% }) %>
          <% } %>
        </div>
      </div>

      <!-- إرسال رسالة -->
      <div class="settings-card">
        <h3>📤 إرسال رسالة من الداشبورد</h3>
        <div class="form-group">
          <label>📢 الروم</label>
          <select id="test_channel" class="select-field">
            <% guild.channels.forEach(ch => { %><option value="<%= ch.id %>">#<%= ch.name %></option><% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>💬 الرسالة</label>
          <input type="text" id="test_message" class="input-field" placeholder="اكتب رسالتك هنا...">
        </div>
        <button onclick="doAction('send_message',{channelId:document.getElementById('test_channel').value,message:document.getElementById('test_message').value})" class="btn-save">📤 إرسال</button>
      </div>
    </div>

    <!-- TAB: WELCOME -->
    <div id="tab-welcome" class="tab-content">
        <p class="tab-desc">يدعم: {user} {username} {server} {count} {id}</p>
      </div>
      <div class="settings-card">
        <h3>🎉 رسالة الترحيب</h3>
        <div class="form-group">
          <label>📢 روم الترحيب</label>
          <select id="welcome_channel" class="select-field">
            <option value="">-- اختر روم --</option>
            <% guild.channels.forEach(ch => { %>
              <option value="<%= ch.id %>" <%= settings.welcome_channel === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>💬 رسالة الترحيب</label>
          <textarea id="welcome_message" class="textarea-field" rows="4" placeholder="مرحباً {user} في {server}!"><%= settings.welcome_message %></textarea>
        </div>
        <div class="form-group">
          <label>🖼️ صورة الترحيب (رابط اختياري)</label>
          <input type="url" id="welcome_image" value="<%= settings.welcome_image %>" class="input-field" placeholder="https://...">
        </div>
        <div class="form-group">
          <label>🎭 رتبة تلقائية عند الدخول</label>
          <select id="welcome_role" class="select-field">
            <option value="">-- بدون رتبة --</option>
            <% guild.roles.forEach(r => { %>
              <option value="<%= r.id %>" <%= settings.welcome_role === r.id ? 'selected' : '' %>><%= r.name %></option>
            <% }) %>
          </select>
        </div>
        <button onclick="saveSection('welcome',{
          welcome_channel: document.getElementById('welcome_channel').value,
          welcome_message: document.getElementById('welcome_message').value,
          welcome_image: document.getElementById('welcome_image').value,
          welcome_role: document.getElementById('welcome_role').value
        })" class="btn-save">💾 حفظ إعدادات الترحيب</button>
      </div>
      <div class="settings-card">
        <h3>👋 رسالة الوداع</h3>
        <div class="form-group">
          <label>📢 روم الوداع</label>
          <select id="leave_channel" class="select-field">
            <option value="">-- بدون --</option>
            <% guild.channels.forEach(ch => { %>
              <option value="<%= ch.id %>" <%= settings.leave_channel === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>💬 رسالة الوداع</label>
          <textarea id="leave_message" class="textarea-field" rows="3" placeholder="وداعاً {username}!"><%= settings.leave_message %></textarea>
        </div>
        <button onclick="saveSection('welcome',{
          leave_channel: document.getElementById('leave_channel').value,
          leave_message: document.getElementById('leave_message').value
        })" class="btn-save">💾 حفظ إعدادات الوداع</button>
      </div>
    </div>

    <!-- TAB: AUTO-REPLY -->
    <div id="tab-autoreply" class="tab-content">
      <div class="tab-header"><h2><i class="fas fa-comment-dots"></i> نظام الرد التلقائي</h2></div>
      <div class="settings-card">
        <h3>➕ إضافة رد تلقائي</h3>
        <div class="form-group">
          <label>🔤 الكلمة / الجملة</label>
          <input type="text" id="ar_word" class="input-field" placeholder="مثال: مرحبا">
        </div>
        <div class="form-group">
          <label>💬 الرد</label>
          <input type="text" id="ar_reply" class="input-field" placeholder="مثال: وعليكم السلام!">
        </div>
        <button onclick="addAutoReply()" class="btn-save">➕ إضافة</button>
      </div>
      <div class="settings-card">
        <h3>📋 الردود الحالية (<span id="reply-count"><%= settings.auto_replys.length %></span>)</h3>
        <div id="replies-list">
          <% if (settings.auto_replys.length === 0) { %>
            <p class="empty-text">لا يوجد ردود تلقائية بعد. أضف أول رد!</p>
          <% } else { %>
            <% settings.auto_replys.forEach(r => { %>
              <div class="reply-item" id="reply-<%= r.word %>">
                <div class="reply-info">
                  <span class="reply-word">🔤 "<%= r.word %>"</span>
                  <span class="reply-arrow">→</span>
                  <span class="reply-text"><%= r.reply %></span>
                </div>
                <button onclick="removeAutoReply('<%= r.word.replace(/'/g, "\\'") %>')" class="btn-sm-danger">🗑️</button>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>

    <!-- TAB: AI -->
    <div id="tab-ai" class="tab-content">
      <div class="tab-header">
        <h2><i class="fas fa-robot"></i> الذكاء الاصطناعي</h2>
        <p class="tab-desc">خصص روماً يرد فيه البوت بالذكاء الاصطناعي على الرسائل</p>
      </div>
      <div class="settings-card">
        <h3>🤖 إعداد روم الذكاء الاصطناعي</h3>
        <div class="form-group">
          <label>📢 روم الذكاء الاصطناعي</label>
          <select id="ai_channel" class="select-field">
            <option value="">-- اختر روم --</option>
            <% guild.channels.forEach(ch => { %>
              <option value="<%= ch.id %>" <%= settings.ai_channel === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="toggle-item">
          <div class="toggle-info">
            <span class="toggle-icon">🤖</span>
            <div>
              <strong>تفعيل الذكاء الاصطناعي</strong>
              <small>البوت سيرد تلقائياً على كل رسائل الروم المحدد</small>
            </div>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" id="ai_enabled" <%= settings.ai_enabled ? 'checked' : '' %>>
            <span class="toggle-slider"></span>
          </label>
        </div>
        <button onclick="saveSection('ai',{
          ai_channel: document.getElementById('ai_channel').value,
          ai_enabled: document.getElementById('ai_enabled').checked
        })" class="btn-save mt-4">💾 حفظ إعدادات الذكاء الاصطناعي</button>
      </div>
      <div class="settings-card">
        <h3>ℹ️ معلومات</h3>
        <p>• البوت سيرد على <strong>كل رسالة</strong> في الروم المحدد</p>
        <p>• يمكن أيضاً إعداده بالأمر <code>/setup-ai</code></p>
        <p>• الردود باللغة العربية بشكل افتراضي</p>
      </div>
    </div>

    <!-- TAB: PROTECTION -->
    <div id="tab-protection" class="tab-content">
      <div class="tab-header">
        <h2><i class="fas fa-shield-alt"></i> نظام الحماية</h2>
        <p class="tab-desc">⚠️ تأكد أن رتبة البوت أعلى رتبة في السيرفر</p>
      </div>
      <div class="settings-card">
        <h3>🔧 روم سجل الحماية</h3>
        <select id="protect_log" class="select-field">
          <option value="">-- بدون سجل --</option>
          <% guild.channels.forEach(ch => { %>
            <option value="<%= ch.id %>" <%= settings.protect_log === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="settings-card">
        <h3>🛡️ أنظمة الحماية</h3>
        <div class="toggles-grid">
          <% const protections = [
            {id:'anti_server_edit', icon:'🏠', label:'حماية السيرفر', desc:'منع تغيير اسم/صورة السيرفر'},
            {id:'anti_channel_edit', icon:'📁', label:'حماية الرومات', desc:'منع حذف/تعديل الرومات'},
            {id:'anti_channel_create', icon:'🚫', label:'منع إنشاء رومات', desc:'باند من ينشئ روم'},
            {id:'anti_role_create', icon:'🎭', label:'منع إنشاء رتب', desc:'باند من ينشئ رتبة'},
            {id:'anti_role_edit', icon:'✏️', label:'حماية تعديل الرتب', desc:'منع تغيير صلاحيات الرتب'},
            {id:'anti_kick', icon:'👟', label:'منع الكيك الجماعي', desc:'باند من يكيك أكثر من 3'},
            {id:'anti_ban', icon:'🔨', label:'منع البان الجماعي', desc:'باند من يبان أكثر من 3'},
            {id:'anti_bots', icon:'🤖', label:'منع إضافة بوتات', desc:'طرد أي بوت يُضاف'},
            {id:'anti_webhook', icon:'🪝', label:'منع الويب هوكس', desc:'حذف أي webhook يُنشأ'},
          ] %>
          <% protections.forEach(p => { %>
            <div class="toggle-item">
              <div class="toggle-info">
                <span class="toggle-icon"><%= p.icon %></span>
                <div>
                  <strong><%= p.label %></strong>
                  <small><%= p.desc %></small>
                </div>
              </div>
              <label class="toggle-switch">
                <input type="checkbox" id="<%= p.id %>" <%= settings[p.id] ? 'checked' : '' %>>
                <span class="toggle-slider"></span>
              </label>
            </div>
          <% }) %>
        </div>
        <button onclick="saveProtection()" class="btn-save mt-4">💾 حفظ إعدادات الحماية</button>
      </div>
    </div>

    <!-- TAB: LOGS -->
    <div id="tab-logs" class="tab-content">
      <div class="tab-header">
        <h2><i class="fas fa-scroll"></i> سجلات اللوج</h2>
      </div>
      <div class="settings-card">
        <div class="logs-grid">
          <% const logTypes = [
            {key:'messagedelete',label:'حذف رسائل',icon:'🗑️'},
            {key:'messageupdate',label:'تعديل رسائل',icon:'✏️'},
            {key:'rolecreate',label:'إنشاء رتبة',icon:'🆕'},
            {key:'roledelete',label:'حذف رتبة',icon:'❌'},
            {key:'rolegive',label:'إعطاء رتبة',icon:'✅'},
            {key:'roleremove',label:'إزالة رتبة',icon:'➖'},
            {key:'channelcreate',label:'إنشاء روم',icon:'📢'},
            {key:'channeldelete',label:'حذف روم',icon:'🗑️'},
            {key:'banadd',label:'باند عضو',icon:'🔨'},
            {key:'bandelete',label:'رفع باند',icon:'🔓'},
            {key:'kickadd',label:'كيك عضو',icon:'👟'},
            {key:'botadd',label:'إضافة بوت',icon:'🤖'},
          ] %>
          <% logTypes.forEach(lt => { %>
            <div class="log-item">
              <label><%= lt.icon %> <%= lt.label %></label>
              <select id="log_<%= lt.key %>" class="select-field-sm">
                <option value="">-- بدون --</option>
                <% guild.channels.forEach(ch => { %>
